# Supabase – kopiraj u .env i popuni (nikad ne commituj .env)
# Frontend koristi samo URL + anon public JWT (ili Publishable; anon JWT osigurava da Edge Functions rade).
VITE_SUPABASE_URL=https://tvoj-project-ref.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=eyJ...anon_public_jwt_ili_publishable_key...

# Opciono: ImgBB API key kao rezerva za upload slika (ako Supabase storage nije konfigurisan ili upload ne uspije)
# Besplatno na https://api.imgbb.com/
# VITE_IMGBB_API_KEY=...

# Hugging Face – za mini asistenta na sajtu (Netlify Functions koristi ovo)
# Dobij ključ na https://huggingface.co/settings/tokens
HUGGINGFACE_API_KEY=hf_...

# Opciono: za lokalni dev bez "netlify dev" – base URL deployovanog sajta
# (npr. https://tvoj-projekat.netlify.app) da asistent radi i na npm run dev
# VITE_NETLIFY_URL=https://tvoj-projekat.netlify.app
